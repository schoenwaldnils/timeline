{
  "name": "timeline",
  "version": "4.0.0",
  "description": "",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "dev": "next dev -p 3002 --experimental-https",
    "build": "next build",
    "lint:ts": "eslint",
    "lint:ts-fix": "eslint --fix",
    "lint:md": "remark . --frail --quiet",
    "lint:md-fix": "remark . --output --quiet",
    "lint": "pnpm lint:ts && pnpm lint:md",
    "lint-fix": "pnpm lint:ts-fix && pnpm lint:md-fix",
    "test:types": "tsc --noEmit",
    "test:int": "vitest run --config ./vitest.config.mts",
    "test:e2e": "playwright test",
    "test": "pnpm test:types && pnpm test:int && pnpm test:e2e && pnpm lint",
    "generate:importmap": "payload generate:importmap",
    "generate:payload-types": "payload generate:types",
    "migrate": "payload migrate",
    "migrate:create": "payload migrate:create",
    "migrate:status": "payload migrate:status",
    "generate:favicons": "real-favicon generate faviconDescription.json faviconData.json public/assets/images/favicons",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "export:contentful": "contentful space export --config contentful-export.config.json --space-id \"$NEXT_PUBLIC_CONTENTFUL_SPACE_ID\" --management-token \"$CONTENTFUL_CMA_TOKEN\"",
    "migrate:contentful": "tsx scripts/import-from-contentful.ts",
    "reindex:algolia": "tsx scripts/reindex-algolia.ts",
    "storybook": "start-storybook -p 6006 --quiet",
    "build-storybook": "build-storybook --loglevel warn",
    "snapshot": "pnpm build-storybook && percy storybook -c .percyrc ./storybook-static",
    "analyze": "cross-env ANALYZE=true next build",
    "snyk-protect": "snyk-protect",
    "prepare": "pnpm snyk-protect && simple-git-hooks"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm exec lint-staged",
    "pre-push": "pnpm build"
  },
  "lint-staged": {
    "*.{ts,tsx,js,mjs,cjs}": "eslint --fix",
    "!(.changeset/**/*)*.md": "remark --output --quiet --frail --silently-ignore"
  },
  "keywords": [],
  "repository": "github:schoenwaldnils/timeline",
  "author": {
    "name": "Nils Schönwald",
    "email": "nils@schoen.world"
  },
  "license": "ISC",
  "dependencies": {
    "@emotion/react": "^11.11.4",
    "@emotion/styled": "^11.11.5",
    "@formatjs/intl-localematcher": "^0.8.10",
    "@payloadcms/db-postgres": "^3.85.1",
    "@payloadcms/next": "^3.85.1",
    "@payloadcms/richtext-lexical": "^3.85.1",
    "@payloadcms/translations": "^3.85.1",
    "@payloadcms/ui": "^3.85.1",
    "@snyk/protect": "^1.1305.1",
    "@svgr/webpack": "^8.1.0",
    "@vercel/analytics": "^2.0.1",
    "algoliasearch": "^5.54.0",
    "array-sort": "^1.0.0",
    "color": "^5.0.3",
    "graphql": "^16.14.2",
    "i18next": "^26.3.1",
    "i18next-resources-to-backend": "^1.2.1",
    "lodash": "^4.18.1",
    "negotiator": "^1.0.0",
    "next": "^16.2.9",
    "next-intl": "^4.13.0",
    "payload": "^3.85.1",
    "postcss-custom-media": "^12.0.1",
    "qs": "^6.15.2",
    "react": "^19.2.7",
    "react-confetti": "^6.1.0",
    "react-cookie": "^8.1.2",
    "react-dom": "^19.2.7",
    "react-highlight-words": "^0.21.0",
    "react-i18next": "^17.0.8",
    "react-icons": "^5.6.0",
    "react-instantsearch": "^7.35.1",
    "react-merge-refs": "^3.0.2",
    "react-query": "^3.39.3",
    "react-swipeable": "^7.0.1",
    "server-only": "^0.0.1",
    "sharp": "^0.35.1",
    "url-loader": "^4.1.1",
    "zustand": "^5.0.14"
  },
  "snyk": true,
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@contentful/rich-text-html-renderer": "^17.2.2",
    "@eslint/js": "^10.0.1",
    "@next/eslint-plugin-next": "16.2.9",
    "@playwright/test": "^1.61.0",
    "@storybook/addon-actions": "^9.0.8",
    "@testing-library/react": "^16.3.2",
    "@types/array-sort": "^1.0.3",
    "@types/color": "^4.2.1",
    "@types/eslint-plugin-jsx-a11y": "^6.10.1",
    "@types/jsdom": "^28.0.3",
    "@types/lodash": "^4.17.24",
    "@types/negotiator": "^0.6.3",
    "@types/node": "^25.9.3",
    "@types/qs": "^6.15.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/react-highlight-words": "^0.20.1",
    "@vitejs/plugin-react": "^6.0.2",
    "contentful-cli": "^4.0.2",
    "dotenv": "^17.4.2",
    "dotenv-flow": "^4.1.0",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "jiti": "^2.7.0",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.4",
    "remark-cli": "^12.0.1",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.1",
    "remark-preset-lint-recommended": "^7.0.1",
    "simple-git-hooks": "^2.13.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "vitest": "^4.1.9",
    "vitest-axe": "^0.1.0"
  },
  "packageManager": "pnpm@11.7.0+sha512.19cc852c120c7125760f2443ee6be0ca5b40f9f50598de1a09a1f177503e010e57c23c77646e01e761de59bf874fb22a3398c33ab9691fc13eb946b6f0f4d620"
}
