    "lint:ts": "eslint . --ext .ts,.tsx",
    "lint:ts-fix": "eslint . --ext .ts,.tsx --fix",
    "lint:types": "tsc --noEmit",
    "generate:gql-types": "graphql-codegen --config codegen.yml -r dotenv-flow/config",
